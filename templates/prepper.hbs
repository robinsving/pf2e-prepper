<div class="pf2e-prepper">
  <div class="prepper-tabs">
    <a class="item" data-tab="current">{{localize "PREPPER.spellList.currentPreparation"}}</a>
    {{#each spellLists as |list|}}
      <a class="item" data-tab="{{list.id}}">{{list.name}}</a>
    {{/each}}
  </div>

  <div class="prepper-tab-content">
    <div class="tab" data-tab="current">
      <div class="prepper-list-info">
        <h3>{{localize "PREPPER.spellList.currentPreparation"}}</h3>
        <button class="prepper-reload-current-btn">
          <i class="fas fa-sync"></i> {{localize "PREPPER.spellListButton.reload"}}
        </button>
        <button class="prepper-new-list-btn">
          <i class="fas fa-plus"></i> {{localize "PREPPER.spellListButton.new"}}
        </button>
      </div>
      
      <div class="prepper-spell-list-container">
        {{#if currentSpells.length}}
          {{#each currentSpells as |entry|}}
            <div class="prepper-spellcasting-entry">
              <h4>{{entry.name}}</h4>
              {{#each entry.levels as |level|}}
                <div class="prepper-spell-level">
                  <h5>{{localize "PREPPER.spellList.spellRank"}} {{level.level}}</h5>
                  <ul class="spell-list">
                    {{#each level.spells as |spell|}}
                      <li class="spell-item">
                        {{spell.name}}
                      </li>
                    {{/each}}
                  </ul>
                </div>
              {{/each}}
            </div>
          {{/each}}
        {{else}}
          <p class="no-spells-message">{{localize "PREPPER.spellList.noSpellsAvailable"}}</p>
        {{/if}}
      </div>
    </div>

    {{#each spellLists as |list|}}
      <div class="tab" data-tab="{{list.id}}">
        <!-- List header with name and metadata -->
        <div class="prepper-list-info">
          <!-- List name -->
          <h3>{{list.name}}</h3>

          <!-- Metadata -->
          <div class="prepper-list-metadata">
            <span>Id: {{list.id}}</span><br>
            <span class="last-used">
              {{#if list.created}}
                {{localize "PREPPER.spellList.createdDate"}}: {{formatDate list.created}}
              {{/if}}
            </span>
          </div>
        </div>

        <!-- Optional description -->
        {{#if list.description}}
        <div class="prepper-list-description">
          {{list.description}}
        </div>
        {{/if}}

        <!-- Spell list details -->
        <div class="prepper-spell-list-container">
          {{#if list.displayEntries.length}}
            {{#each list.displayEntries as |entry|}}
              <!-- Spellcasting entry with name and spells by level -->
              <div class="prepper-spellcasting-entry">
                <h4>{{entry.name}}</h4>
                {{#each entry.levels as |level|}}
                  <div class="prepper-spell-level">
                    <h5>{{localize "PREPPER.spellList.spellRank"}} {{level.level}}</h5>
                    <ul class="spell-list">
                      {{#each level.spells as |spell|}}
                        <li class="spell-item">
                          {{spell.name}}
                        </li>
                      {{/each}}
                    </ul>
                  </div>
                {{/each}}
              </div>
            {{/each}}
           {{else}}
            <p class="no-spells-message">{{localize "PREPPER.spellList.noSpellsAvailable"}}</p>
          {{/if}}
        </div>
        
        <!-- Action buttons -->
        <div class="prepper-list-actions">
          <button class="prepper-load-list-btn" data-list-id="{{list.id}}">
            <i class="fas fa-book-open"></i> {{localize "PREPPER.spellListButton.load"}}
          </button>
          <button class="prepper-reset-list-btn" data-list-id="{{list.id}}">
            <i class="fas fa-sync-alt"></i> {{localize "PREPPER.spellListButton.reset"}}
          </button>
          <button class="prepper-duplicate-list-btn" data-list-id="{{list.id}}">
            <i class="fas fa-copy"></i> {{localize "PREPPER.spellListButton.duplicate"}}
          </button>
          <button class="prepper-rename-list-btn" data-list-id="{{list.id}}">
            <i class="fas fa-edit"></i> {{localize "PREPPER.spellListButton.rename"}}
          </button>
          <button class="prepper-delete-list-btn" data-list-id="{{list.id}}">
            <i class="fas fa-trash"></i> {{localize "PREPPER.spellListButton.delete"}}
          </button>
        </div>
      </div>
    {{/each}}

  </div>
</div>
